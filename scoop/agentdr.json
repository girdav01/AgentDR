    "bin": "adr-agent.exe",
    "post_install": [
        "if (-not (Test-Path \"$env:ProgramData\\AgentDR\")) { New-Item -ItemType Directory -Path \"$env:ProgramData\\AgentDR\" | Out-Null }",
        "if (-not (Test-Path \"$env:ProgramData\\AgentDR\\config.toml\")) {",
        "    @\"",
        "watch_directories = [\"$env:USERPROFILE\"]",
        "",
        "[otlp]",
        "enabled = true",
        "bind = \"127.0.0.1:4318\"",
        "redact_content = true",
        "",
        "[mcp]",
        "inventory_on_start = true",
        "rescan_seconds = 600",
        "\"@ | Out-File -Encoding ASCII \"$env:ProgramData\\AgentDR\\config.toml\"",
        "}"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/girdav01/agentdr/releases/download/v$version/adr-agent-$version-x86_64-pc-windows-msvc.zip"

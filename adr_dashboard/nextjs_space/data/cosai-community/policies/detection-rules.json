{
  "$schema": "https://cosai.dev/schemas/detection-rules-v1.json",
  "version": "1.0.0",
  "description": "CoSAI Community Default Detection Rules — pre-built threat-detection policies for AI agent monitoring aligned with the AITF OCSF Class-Reuse Model (reused OCSF classes + ai_operation profile).",
  "rules": [
    { "id": "AITF-DET-001", "name": "Unusual Token Usage",            "category": "Inference",      "severity": "medium",   "enabled": true, "ocsf_class": 2004, "ai_operation": "cost_anomaly" },
    { "id": "AITF-DET-002", "name": "Model Switching Attack",         "category": "Inference",      "severity": "high",     "enabled": true, "ocsf_class": 2004, "ai_operation": "guardrail" },
    { "id": "AITF-DET-003", "name": "Prompt Injection Attempt",       "category": "Inference",      "severity": "critical", "enabled": true, "ocsf_class": 2004, "ai_operation": "prompt_injection" },
    { "id": "AITF-DET-004", "name": "Excessive Cost Spike",           "category": "Inference",      "severity": "high",     "enabled": true, "ocsf_class": 2004, "ai_operation": "cost_anomaly" },
    { "id": "AITF-DET-005", "name": "Agent Loop Detection",           "category": "Agent",          "severity": "medium",   "enabled": true, "ocsf_class": 2004, "ai_operation": "guardrail" },
    { "id": "AITF-DET-006", "name": "Unauthorized Agent Delegation",  "category": "Agent",          "severity": "high",     "enabled": true, "ocsf_class": 2004, "ai_operation": "permission_escalation" },
    { "id": "AITF-DET-007", "name": "Agent Session Hijack",           "category": "Agent",          "severity": "critical", "enabled": true, "ocsf_class": 2004, "ai_operation": "permission_escalation" },
    { "id": "AITF-DET-008", "name": "Excessive Tool Calls",           "category": "Agent",          "severity": "medium",   "enabled": true, "ocsf_class": 2004, "ai_operation": "guardrail" },
    { "id": "AITF-DET-009", "name": "MCP Server Impersonation",       "category": "MCP/Tool",       "severity": "critical", "enabled": true, "ocsf_class": 2004, "ai_operation": "prompt_injection" },
    { "id": "AITF-DET-010", "name": "Tool Permission Bypass",         "category": "MCP/Tool",       "severity": "high",     "enabled": true, "ocsf_class": 2004, "ai_operation": "permission_escalation" },
    { "id": "AITF-DET-011", "name": "Data Exfiltration via Tools",    "category": "MCP/Tool",       "severity": "critical", "enabled": true, "ocsf_class": 2004, "ai_operation": "data_exfiltration" },
    { "id": "AITF-DET-012", "name": "PII Exfiltration Chain",         "category": "Security",       "severity": "critical", "enabled": true, "ocsf_class": 2004, "ai_operation": "data_exfiltration" },
    { "id": "AITF-DET-013", "name": "Jailbreak Escalation",           "category": "Security",       "severity": "high",     "enabled": true, "ocsf_class": 2004, "ai_operation": "prompt_injection" },
    { "id": "AITF-DET-014", "name": "Supply Chain Compromise",        "category": "Security",       "severity": "critical", "enabled": true, "ocsf_class": 2002, "ai_operation": "supply_chain" },
    { "id": "AITF-DET-015", "name": "Malicious Skill/Plugin Loaded",  "category": "Agent/Plugin",   "severity": "critical", "enabled": true, "ocsf_class": 2004, "ai_operation": "supply_chain" },
    { "id": "AITF-DET-016", "name": "Unauthorized Messaging Channel", "category": "Agent/Comms",    "severity": "high",     "enabled": true, "ocsf_class": 2004, "ai_operation": "data_exfiltration" },
    { "id": "AITF-DET-017", "name": "Shell Command Execution",        "category": "Agent/System",   "severity": "high",     "enabled": true, "ocsf_class": 2004, "ai_operation": "permission_escalation" },
    { "id": "AITF-DET-018", "name": "Credential / Secret Access",     "category": "Security",       "severity": "critical", "enabled": true, "ocsf_class": 2004, "ai_operation": "data_exfiltration" },
    { "id": "AITF-DET-019", "name": "Cross-Platform Data Relay",      "category": "Security",       "severity": "critical", "enabled": true, "ocsf_class": 2004, "ai_operation": "data_exfiltration" },
    { "id": "AITF-DET-020", "name": "Unvetted Skill Installation",    "category": "Agent/Plugin",   "severity": "high",     "enabled": true, "ocsf_class": 2004, "ai_operation": "supply_chain" }
  ]
}
